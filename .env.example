# ============================================
# 画词AI · Draw Word — 环境配置
# ============================================
#
# 🇨🇳 全部使用国内服务，无需翻墙

# ---------- 文本分析：DeepSeek ----------
# 注册：https://platform.deepseek.com（中国手机号 + 微信/支付宝）
# 价格：约 ¥1/百万 token
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ---------- 图片生成：通义万相（阿里云百炼）----------
# 注册：https://bailian.console.aliyun.com（阿里云账号）
# 开通：百炼控制台 → 模型广场 → 通义万相 → 开通
# 价格：新用户有免费额度，之后按量付费
# 不填则使用免费备用图床（效果一般）
IMAGE_API_KEY=your-bailian-key-here
